<p>
  <label>Client ID:</label>
  <%= text_field_tag 'settings[client_id]', @settings[:client_id], size: 60 %>
</p>
<p>
  <label>Client Secret:</label>
  <%= text_field_tag 'settings[client_secret]', @settings[:client_secret], size: 60 %>
</p>
<p>
  <label>Callback URL:</label>
  <%= text_field_tag 'settings[callback_url]', @settings[:callback_url], size: 60, placeholder: 'https://redmine.example.com/oauth2callback' %>
  <br><em>Must match the redirect URI in Google Cloud Console.</em>
</p>
<p>
  <label>Allowed domains (one per line):</label>
  <%= text_area_tag 'settings[allowed_domains]', @settings[:allowed_domains], rows: 3, cols: 60 %>
</p>
<p>
  <label>Enable OAuth authentication:</label>
  <%= check_box_tag 'settings[oauth_authentification]', true, @settings[:oauth_authentification] %>
</p>
<p>
  <label>Hide password login form:</label>
  <%= check_box_tag 'settings[hide_password_login]', true, @settings[:hide_password_login] %>
  <br><em>Only show Google login button on the login page.</em>
</p>
